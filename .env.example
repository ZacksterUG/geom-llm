# Copy this file to .env and fill in your values

# PostgreSQL Database
POSTGRES_DB=stereometry_db
POSTGRES_USER=geom_user
POSTGRES_PASSWORD=geom_password123
POSTGRES_PORT=5432

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# Ollama
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_PORT=11434
OLLAMA_HOST=geom-ollama

# Backend (FastAPI) - will be added later
BACKEND_PORT=8000

# Liquibase
LIQUIBASE_CHANGELOG_FILE=/liquibase/changelog-master.xml
LIQUIBASE_URL=jdbc:postgresql://geom-db:5432/stereometry_db
LIQUIBASE_USERNAME=geom_user
LIQUIBASE_PASSWORD=geom_password123

# Network
NETWORK_NAME=geom-network